# PostgreSQL (Neon) with pgvector extension
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# LLM + embeddings (Gemini free tier)
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_GEN_MODEL="gemini-flash-latest"
GEMINI_EMBED_MODEL="gemini-embedding-001"
EMBED_DIM="768"
# Optional switchable generation provider
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# App
PORT="4000"
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# Demo account (one-click login)
DEMO_EMAIL="demo@verba.app"
DEMO_PASSWORD="demo1234"

# Limits (protect the free quota)
MAX_UPLOAD_MB="8"
DAILY_QUERY_CAP="200"
DAILY_INGEST_CAP="50"
MAX_DOC_CHARS="200000"
